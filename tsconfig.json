{
  "compilerOptions": {
    "baseUrl": "./src",
		"declaration": true,
		"emitDeclarationOnly": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"moduleResolution": "node",
		"esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "components/*": ["./src/components/*"],
      "core/*": ["./src/core/*"]
    }
	},
  "include": ["src"],
  "exclude": ["node_modules/**/*"]
}
